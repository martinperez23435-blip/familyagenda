rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function onlyChangingAssignment() {
      let allowed = ['dropoff', 'pickup'].toSet();
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(allowed);
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == userId;
    }

    // MINORS
    match /minors/{minorId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ACTIVITY TEMPLATES
    match /activity_templates/{templateId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // CALENDAR EVENTS
    match /calendar_events/{eventId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (isAuth() && onlyChangingAssignment());
    }

    // NOTIFICATIONS
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.toUserId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.toUserId == request.auth.uid;
    }
  }
}
